WavyLabs/
# include/ is a Windows junction → lmms-core/include (created by mklink /J)
include/
# Firecrawl API research cache
.firecrawl/
# Windows NUL device artifact
nul
*/nul
# License server local dev database
wavy-license-server/dev.db
wavy-license-server/*.db
# Temporary debug build scripts
build_and_log.bat
